{
  "name": "apna-cafe-backend",
  "version": "1.0.0",
  "description": "Backend for Apna Cafe",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "db:push": "npx prisma db push",
    "db:seed": "npx ts-node prisma/seed.ts",
    "db:reset": "npx prisma db push --force-reset && npx ts-node prisma/seed.ts",
    "db:update-images": "npx ts-node prisma/update-image-urls.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@clerk/clerk-sdk-node": "^5.1.3",
    "@prisma/client": "^5.12.0",
    "@supabase/supabase-js": "^2.105.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "razorpay": "^2.9.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.4",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "prisma": "^5.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
